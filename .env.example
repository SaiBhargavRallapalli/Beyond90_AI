# ─────────────────────────────────────────────
# AI Provider — groq | gemini | claude
# ─────────────────────────────────────────────

# Set to "groq" (default), "gemini", or "claude"
AI_PROVIDER=groq

# Groq API key (used when AI_PROVIDER=groq)
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini API key (used when AI_PROVIDER=gemini)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# Anthropic Claude API key (used when AI_PROVIDER=claude)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# App configuration
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Beyond90 AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
