# ─────────────────────────────────────────────
# AI Provider — switch between Gemini and Claude
# ─────────────────────────────────────────────

# Set to "gemini" (default) or "claude"
AI_PROVIDER=gemini

# Google Gemini API key (used when AI_PROVIDER=gemini)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude API key (used when AI_PROVIDER=claude)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# App configuration
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Beyond90 AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
